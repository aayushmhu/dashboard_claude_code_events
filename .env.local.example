# SQLite database path (default: ~/.claude-dashboard/dashboard.db)
# DB_PATH=/Users/yourname/.claude-dashboard/dashboard.db

# App URL — uncomment and set if running on a non-default port or custom domain
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: your display name for the dashboard's actor labels.
# If unset, human messages render as "User" instead of a specific name.
# NEXT_PUBLIC_USER_NAME=Aayush
